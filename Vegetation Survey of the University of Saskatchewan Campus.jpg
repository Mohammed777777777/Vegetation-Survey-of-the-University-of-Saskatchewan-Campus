7.707L8.718 8l3.303 3.303-.707.707L8.01 8.707l-.01.01-.01-.01-3.304 3.303z" class="jsx-3457670934"></path></svg></span></button></div></div></div></div></div></div></div><figcaption id="caption-:r5n:" class="jsx-3232094028 caption"><p data-testid="TextInput" class="text-input">Vegetation Survery points in University of Saskatchewan Campus (Note: This map uses scale-dependent labelling and layers — zooming in will reveal additional labels and feature layers for a more detailed view. Labels were configured using Arcade expression language in ArcGIS Online to control the display of vegetation attributes dynamically across zoom levels)</p></figcaption></figure></div></div><div data-blockid="n-dDVykO" id="n-dDVykO" class="jsx-1608645298 layout-wrapper"><div class="jsx-1766271777 grid-item-lite"><div data-blockid="n-dDVykO" class="jsx-781984284 text-viewer"><p data-testid="Paragraph" class="jsx-1867417704 jsx-1394512618 medium responsive">The following Arcade expression was used in the web map, which will be visible when zooming into the map:</p></div></div></div><div data-blockid="n-GBnGWI" id="n-GBnGWI" class="jsx-2839305906 layout-wrapper"><div class="jsx-1766271777 grid-item-lite"><div class="jsx-3739383261 sticky-container"><div class="jsx-3739383261 jsx-8197ccb96e56dbb8 copy-buttons buttons"><div class="jsx-3739383261 buttons-wrapper"><button class="button single-icon themed-control icon-button button-styles with-border with-background large jsx-1128713261 icon-button jsx-774070654" data-testid="copy-code-snippet-button" type="button"><div class="icon-wrapper jsx-774070654"><span aria-hidden="true" class="jsx-3457670934 icon"><svg viewBox="0 0 16 16" class="jsx-3457670934"><path d="M6 1h4v3.186l.814.814H14v7h-2v1h3V3.6L11.4 0H5v2h1zm5 0h.31L14 3.69V4h-3zm0 5.6L7.4 3H1v13h10zM10 15H2V4h4v4h4zm0-8H7V4h.31L10 6.69zM3 9h6v1H3zm3 3h1v1H3v-1z" class="jsx-3457670934"></path></svg></span><span class="visually-hidden">Copy code snippet</span></div></button></div></div><div class="jsx-3739383261 sticky-background"></div></div><pre data-blockid="n-GBnGWI" class="jsx-2065198100 pre-tag-container with-themed-shape language-txt" tabindex="0"><code class="language-txt">$feature["Plant_growth_status"]
" Growth Status: " +DomainName($feature, "Plant_growth_status")</code></pre></div></div><div data-blockid="n-byWpbI" id="n-byWpbI" class="jsx-2937103378 layout-wrapper"><div class="jsx-1766271777 grid-item-lite"><div class="jsx-1068227533 text-container"><div class="jsx-1068227533 link-spacer-container"><div class="jsx-1068227533 link-spacer"><button aria-label="Copy section link" aria-describedby=":r5r:" class="jsx-1068227533 link-button" data-popover-state="closed"><span aria-hidden="true" class="jsx-1135053170 icon"><svg viewBox="0 0 16 16" class="jsx-1135053170"><path d="M5 9.5a5 5 0 0 0 .048.493l-.023-.018-3-3a3.5 3.5 0 1 1 4.95-4.95l3 3a3.486 3.486 0 0 1-1.31 5.76l-.226-.225a1.5 1.5 0 0 1-.37-.631 2.495 2.495 0 0 0 1.199-4.197l-3-3a2.5 2.5 0 1 0-3.536 3.536L5.09 8.625A4.5 4.5 0 0 0 5 9.5m11 3a3.48 3.48 0 0 0-1.025-2.475l-3-3-.023-.018A5 5 0 0 1 12 7.5a4.5 4.5 0 0 1-.089.876l2.357 2.356a2.5 2.5 0 0 1-.009 3.544 2.56 2.56 0 0 1-3.527-.008l-3-3a2.5 2.5 0 0 1-.094-3.436 2.43 2.43 0 0 1 1.3-.74 1.5 1.5 0 0 0-.377-.652l-.222-.222a3.482 3.482 0 0 0-1.314 5.757l3 3a3.5 3.5 0 0 0 4.937.012l-.351-.355.352.355A3.48 3.48 0 0 0 16 12.5" class="jsx-1135053170"></path></svg></span></button></div></div><div data-blockid="n-byWpbI" class="jsx-781984284 text-viewer"><h3 id=":r5r:" data-testid="Heading" class="jsx-2728492018 heading responsive jsx-2895946300">Vegetation Characteristics</h3></div></div></div></div><div data-blockid="n-fzVTXC" id="n-fzVTXC" class="jsx-2937103378 layout-wrapper"><div class="jsx-1766271777 grid-item-lite"><div class="jsx-833223251 text-container"><div class="jsx-833223251 link-spacer-container"><div class="jsx-833223251 link-spacer"><button aria-label="Copy section link" aria-describedby=":r5u:" class="jsx-833223251 link-button" data-popover-state="closed"><span aria-hidden="true" class="jsx-1135053170 icon"><svg viewBox="0 0 16 16" class="jsx-1135053170"><path d="M5 9.5a5 5 0 0 0 .048.493l-.023-.018-3-3a3.5 3.5 0 1 1 4.95-4.95l3 3a3.486 3.486 0 0 1-1.31 5.76l-.226-.225a1.5 1.5 0 0 1-.37-.631 2.495 2.495 0 0 0 1.199-4.197l-3-3a2.5 2.5 0 1 0-3.536 3.536L5.09 8.625A4.5 4.5 0 0 0 5 9.5m11 3a3.48 3.48 0 0 0-1.025-2.475l-3-3-.023-.018A5 5 0 0 1 12 7.5a4.5 4.5 0 0 1-.089.876l2.357 2.356a2.5 2.5 0 0 1-.009 3.544 2.56 2.56 0 0 1-3.527-.008l-3-3a2.5 2.5 0 0 1-.094-3.436 2.43 2.43 0 0 1 1.3-.74 1.5 1.5 0 0 0-.377-.652l-.222-.222a3.482 3.482 0 0 0-1.314 5.757l3 3a3.5 3.5 0 0 0 4.937.012l-.351-.355.352.355A3.48 3.48 0 0 0 16 12.5" class="jsx-1135053170"></path></svg></span></button></div></div><div data-blockid="n-fzVTXC" class="jsx-781984284 text-viewer"><h4 id=":r5u:" data-testid="Heading" class="jsx-2728492018 heading responsive jsx-2895946300">Plant Form Chart</h4></div></div></div></div><div data-blockid="n-qkhDC7" id="n-qkhDC7" class="jsx-1608645298 layout-wrapper"><div class="jsx-1766271777 grid-item-lite"><div data-blockid="n-qkhDC7" class="jsx-781984284 text-viewer"><p data-testid="Paragraph" class="jsx-1867417704 jsx-1394512618 medium responsive">Of the 25 vegetation specimens recorded during the survey, Chart 1 shows that the majority were classified as trees, accounting for 68% of all samples (17 points), while shrubs made up the remaining 32% (8 points). This distribution reflects the general character of the University of Saskatchewan campus, where mature trees are a dominant feature of the landscape across open green spaces and along pathways.</p></div></div></div><div data-blockid="n-e0TUSv" id="n-e0TUSv" class="jsx-3464613298 layout-wrapper"><div class="jsx-255522243 grid-item-lite"><div class="jsx-1576022888 dynamic-grid"><figure class="jsx-2537067885 jsx-3605602151 media-wrapper fill-parent with-caption"><div class="jsx-2537067885 jsx-3605602151 media-wrapper-children fill-parent"><div class="jsx-3069096407 wrapper"><ul class="jsx-3069096407 dynamic-grid-container collapsible"><li data-grid-key="0-1-0-1" class="jsx-714787099 item collapsible"><figure class="jsx-2537067885 jsx-3605602151 media-wrapper fi